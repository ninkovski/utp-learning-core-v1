{
  "name": "mini-lms-backend",
  "version": "0.2.0",
  "private": true,
  "description": "Mini LMS backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "prisma:generate": "node ./node_modules/prisma/build/index.js generate --schema=prisma/schema.prisma",
    "start": "npm run prisma:generate && node dist/server.js",
    "start:azure": "npm run prisma:generate && node dist/server.js",
    "test": "jest --config jest.config.ts --runInBand",
    "test:watch": "jest --config jest.config.ts --watch",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "prisma": "^5.7.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "morgan": "^1.10.0",
    "@prisma/client": "^5.7.1",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.12",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "typescript-eslint": "^8.0.1",
    "@types/jsonwebtoken": "^9.0.6",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  }
}
